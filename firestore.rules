rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /locations/{locationId} {
      // Require authentication to read the scan counts on the dashboard.
      // The public index.html page only increments data and doesn't read it.
      allow read: if request.auth != null;
      
      // Prevent direct creation entirely from the external redirect client side
      // Locations must be pre-populated via the Admin Dashboard.
      // This enforces that only logged-in Firebase Auth users can create locations.
      allow create: if request.auth != null && 
                       request.resource.data.keys().hasAll(['scans']) &&
                       request.resource.data.scans >= 0;

      // Allow updating an existing location if they only increment by 1
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['scans', 'lastScanned']) &&
                       request.resource.data.scans == resource.data.scans + 1;
                       
      // Prevent deleting documents directly
      allow delete: if false;
    }
  }
}

